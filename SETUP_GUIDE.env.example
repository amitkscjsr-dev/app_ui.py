# ═══════════════════════════════════════════════════════
# PHASE 2 — New keys to add to your existing .env
# ═══════════════════════════════════════════════════════

# ── Step 1: LinkedIn Developer App ────────────────────
# Go to: linkedin.com/developers → Create app
LINKEDIN_CLIENT_ID=your_client_id_here
LINKEDIN_CLIENT_SECRET=your_client_secret_here
LINKEDIN_REDIRECT_URI=http://localhost:8080/callback

# ── Step 2: Run linkedin_auth.py (auto-fills these) ───
LINKEDIN_ACCESS_TOKEN=    # auto-filled by linkedin_auth.py
LINKEDIN_PERSON_URN=      # auto-filled by linkedin_auth.py
LINKEDIN_REFRESH_TOKEN=   # auto-filled by linkedin_auth.py
LINKEDIN_TOKEN_EXPIRY=    # auto-filled by linkedin_auth.py

# ── Step 3: Make.com webhook ──────────────────────────
# Create scenario → add Webhook module → copy URL here
MAKE_WEBHOOK_URL=https://hook.eu1.make.com/your_unique_id

# ── Step 4: Telegram notifications (optional) ─────────
# 1. Message @BotFather on Telegram → /newbot
# 2. Copy the token it gives you
# 3. Start a chat with your bot, then visit:
#    https://api.telegram.org/bot<TOKEN>/getUpdates
#    to find your chat_id
TELEGRAM_BOT_TOKEN=1234567890:ABCDefGhIJKlmNoPQRsTUVwxyZ
TELEGRAM_CHAT_ID=987654321


# ═══════════════════════════════════════════════════════
# MAKE.COM SCENARIO — STEP BY STEP SETUP
# ═══════════════════════════════════════════════════════
#
# Go to make.com → Create a new scenario
#
# MODULE 1: Webhooks → Custom webhook
# ────────────────────────────────────
# - Click "Add" → name it "AI Content OS"
# - Copy the webhook URL → paste into MAKE_WEBHOOK_URL above
# - Run your app once and click "Schedule" to send a test payload
# - Make.com will auto-detect the payload structure
# - Fields it will see:
#     post_content  (string)
#     image_url     (string)
#     topic         (string)
#     niche         (string)
#     publish_at    (string — ISO datetime)
#     notify        (boolean)
#
# MODULE 2: Flow Control → Sleep
# ───────────────────────────────
# - Add after Webhook
# - Set "Resume execution" to: {{1.publish_at}}
#   (this is the datetime your app sends)
# - Make.com will pause the scenario until that exact moment
#
# MODULE 3: LinkedIn → Create a Post
# ────────────────────────────────────
# - Connect your LinkedIn account (OAuth in Make.com)
# - Commentary: {{1.post_content}}
# - Visibility: PUBLIC
# - If adding image:
#     Add a sub-step: LinkedIn → Upload a File
#     URL: {{1.image_url}}
#     Then reference the uploaded file ID in Create Post
#
# MODULE 4: Google Sheets → Add a Row (optional but recommended)
# ───────────────────────────────────────────────────────────────
# - Create a Google Sheet with columns:
#     Timestamp | Topic | Niche | Published At | Post URL | Image URL
# - Spreadsheet: select your sheet
# - Map fields:
#     Timestamp:    {{now}}
#     Topic:        {{1.topic}}
#     Niche:        {{1.niche}}
#     Published At: {{1.publish_at}}
#     Post URL:     {{3.id}}   (LinkedIn post ID from Module 3)
#     Image URL:    {{1.image_url}}
#
# MODULE 5: Telegram → Send a Message (optional)
# ────────────────────────────────────────────────
# - Connect your Telegram bot
# - Chat ID: your TELEGRAM_CHAT_ID
# - Message:
#     Your LinkedIn post is live!
#     Topic: {{1.topic}}
#     Published: {{1.publish_at}}
#
# SAVE AND ACTIVATE THE SCENARIO
# - Toggle the scenario to ON (bottom left)
# - Set scheduling to "Immediately" (runs when webhook fires)
# - Test end-to-end from your Streamlit app
#
# ═══════════════════════════════════════════════════════
# LINKEDIN DEVELOPER APP — STEP BY STEP
# ═══════════════════════════════════════════════════════
#
# 1. Go to linkedin.com/developers → My Apps → Create App
#
# 2. Fill in:
#    App name:       AI Content OS (or anything)
#    LinkedIn Page:  Your company page (required — create one if needed)
#    Privacy policy: https://yoursite.com/privacy (use any URL)
#    App logo:       Upload any image
#
# 3. On the "Products" tab, request:
#    - Share on LinkedIn          ← gives w_member_social
#    - Sign In with LinkedIn      ← gives r_liteprofile, r_emailaddress
#    Both are approved instantly (no review needed)
#
# 4. On the "Auth" tab:
#    - Copy Client ID → paste into .env
#    - Copy Client Secret → paste into .env
#    - Add Authorized redirect URL: http://localhost:8080/callback
#    - Save
#
# 5. Run: python linkedin_auth.py
#    - Browser opens → sign in → authorize
#    - Token is saved to .env automatically
#
# 6. Verify: check .env for LINKEDIN_ACCESS_TOKEN and LINKEDIN_PERSON_URN
#
# TOKEN RENEWAL SCHEDULE
# ─────────────────────
# Tokens last 60 days. Set a calendar reminder at day 55.
# Run: python linkedin_auth.py  (takes 2 minutes)
# Or call: refresh_access_token() from linkedin_auth.py
#
# ═══════════════════════════════════════════════════════
# HOW TO ADD PUBLISH TAB TO YOUR EXISTING app.py
# ═══════════════════════════════════════════════════════
#
# At the top of your app.py, add:
#   from publish_tab import render_publish_tab
#
# In your final step (wherever you currently have "Publish"):
#   render_publish_tab(
#       post_content = st.session_state.final_post,
#       image_url    = st.session_state.get("generated_image_url"),
#       topic        = st.session_state.selected_topic.get("title", ""),
#       niche        = st.session_state.niche,
#   )
#
# That's it — the tab handles mode selection, scheduling, token
# status, Make.com dispatch, and Telegram notifications.
