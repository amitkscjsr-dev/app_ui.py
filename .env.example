# ════════════════════════════════════════════════════════════
# AI CONTENT OS — Environment Variables
# Copy this file to .env and fill in your keys
# ════════════════════════════════════════════════════════════

# ── AI Models (Required for Phase 1) ──────────────────────
ANTHROPIC_API_KEY=your_anthropic_key_here        # claude.ai/settings → API keys
OPENAI_API_KEY=your_openai_key_here              # platform.openai.com/api-keys

# ── Research (Highly Recommended) ─────────────────────────
TAVILY_API_KEY=your_tavily_key_here              # tavily.com — free 1000 req/month

# ── LinkedIn Publishing (Phase 2) ─────────────────────────
# Apply at: linkedin.com/developers/apps → Create app
# Needs: w_member_social permission
LINKEDIN_ACCESS_TOKEN=your_linkedin_token_here
LINKEDIN_PERSON_URN=urn:li:person:YOUR_ID_HERE   # Get from /v2/me API call

# ── Automation (Phase 2) ──────────────────────────────────
# Create a Make.com scenario with a Webhook trigger
MAKE_WEBHOOK_URL=https://hook.eu1.make.com/your_webhook_id

# ── Notifications (Optional) ──────────────────────────────
# Create bot via @BotFather on Telegram
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here

# ── Media Storage (Phase 3) ───────────────────────────────
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_key
CLOUDINARY_API_SECRET=your_cloudinary_secret

# ── Database (Phase 3) ────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your_supabase_anon_key

# ── Phase 3: Audio / Video ────────────────────────────────
ELEVENLABS_API_KEY=your_elevenlabs_key
HEYGEN_API_KEY=your_heygen_key

# ── Analytics (Phase 4) ───────────────────────────────────
GOOGLE_SHEETS_CREDENTIALS_PATH=credentials.json
GOOGLE_SHEETS_SPREADSHEET_ID=your_sheet_id
